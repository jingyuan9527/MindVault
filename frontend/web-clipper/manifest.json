{
  "manifest_version": 3,
  "name": "MindVault Clipper",
  "version": "1.0",
  "description": "一键将网页内容保存到 MindVault 知识库",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["http://localhost:8080/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
